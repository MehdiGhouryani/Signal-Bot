# این فایل رو کپی کن به نام .env و مقادیر واقعی رو داخلش پر کن.
# فایل .env هرگز نباید commit بشه (داخل .gitignore هست).

# توکن ربات از BotFather — حتماً از توکن جدید استفاده کن (قبلی لو رفته و باید Revoke بشه)
BOT_TOKEN=

# آیدی عددی ادمین‌ها، با کاما جدا از هم (مثال: 111111111,222222222)
ADMIN_IDS=

# کلید API نوپیمنتس (NOWPayments) برای شارژ استخر جایزه
NOWPAYMENTS_API_KEY=

# آدرسی که بعد از پرداخت کاربر بهش هدایت می‌شه (لینک ربات یا کانال)
SUCCESS_URL=https://t.me/your_bot_username

# یوزرنیم کانال برای پست خودکار لیدربورد — اختیاری، خالی بذار اگه نمی‌خوای
CHANNEL_ID=

# مسیر فایل دیتابیس — اختیاری، پیش‌فرض signals.db
DB_FILE=signals.db

# ══════════════════════════════════════════════════════════
# وب‌هوک IPN نوپیمنتس (اختیاری، فاز ۵) — برای تأیید خودکار پرداخت به‌جای کلیک دستی.
# اگه پرش نکنی، ربات فقط با دکمه‌ی «چک وضعیت پرداخت» دستی کار می‌کنه (بدون کرش).
# ══════════════════════════════════════════════════════════
# سکرت IPN از داشبورد NOWPayments → Store Settings
NOWPAYMENTS_IPN_SECRET=

# آدرس عمومی HTTPS که این ربات روش در دسترسه، به‌علاوه مسیر /nowpayments-ipn
# مثال: https://yourdomain.com/nowpayments-ipn
IPN_CALLBACK_URL=

# پورت داخلی که سرور وب‌هوک روش گوش می‌ده (باید از طریق ریورس‌پروکسی/دامنه به IPN_CALLBACK_URL وصل بشه)
IPN_WEBHOOK_PORT=8443
